# --- Database ---
DB_HOST=your-managed-postgres-host
DB_PORT=5432
DB_NAME=magickvoice
DB_USER=magickvoice_app
DB_PASSWORD=change-me
DB_CA_CERT_PATH=./secrets/db-ca.pem
DB_SSL_MODE=verify-full

# --- Auth ---
JWT_SECRET=replace-with-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=1440

# Pepper for hashing client IPs in scan_events. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
# Do NOT rotate after data exists — rotating invalidates unique-visitor counts.
IP_HASH_PEPPER=replace-with-a-long-random-string

# Cookie name + flags
AUTH_COOKIE_NAME=mv_session
AUTH_COOKIE_SECURE=true
AUTH_COOKIE_SAMESITE=lax

# --- Default super admin seed ---
DEFAULT_SUPERADMIN_EMAIL=superadmin@magickvoice.com
DEFAULT_SUPERADMIN_PASSWORD=Admin@123

# --- App ---
HOSTING_ADDRESS=https://app.yourdomain.com
FRONTEND_ORIGIN=http://localhost:3000
PORT=8000
ENVIRONMENT=development
